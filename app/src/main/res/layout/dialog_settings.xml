<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/language_label"
        android:textAppearance="?attr/textAppearanceTitleMedium" />

    <RadioGroup
        android:id="@+id/language_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/lang_english"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/language_english" />

        <RadioButton
            android:id="@+id/lang_french"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/language_french" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/word_length_label"
        android:textAppearance="?attr/textAppearanceTitleMedium" />

    <RadioGroup
        android:id="@+id/length_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/length_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/word_length_format" />

        <RadioButton
            android:id="@+id/length_5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/word_length_format" />

        <RadioButton
            android:id="@+id/length_6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/word_length_format" />

        <RadioButton
            android:id="@+id/length_7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/word_length_format" />
    </RadioGroup>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/unique_letters_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/unique_letters_only" />
</LinearLayout>
